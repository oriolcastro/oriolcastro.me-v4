{
  "name": "oriolcastro.me",
  "version": "1.0.0",
  "private": false,
  "description": "My personal blog",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "build:pagefind": "astro build && pagefind --site dist --output-path public/pagefind",
    "check": "tsc -noEmit",
    "check:astro": "astro check",
    "dev": "astro dev",
    "format": "prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "lint": "oxlint",
    "prepare": "is-ci || pnpm exec simple-git-hooks",
    "preview": "astro preview",
    "start": "astro dev"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "pnpm run format --"
    ],
    "package.json": "sort-package-json"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@astrojs/solid-js": "6.0.1",
    "astro": "6.1.2",
    "astro-expressive-code": "0.41.7",
    "astro-icon": "1.1.5",
    "astro-robots-txt": "1.0.0",
    "cheerio": "1.2.0",
    "hastscript": "9.0.1",
    "mdast-util-directive": "3.1.0",
    "mdast-util-to-markdown": "2.1.2",
    "mdast-util-to-string": "4.0.0",
    "rehype-external-links": "3.0.0",
    "rehype-unwrap-images": "1.0.0",
    "remark-directive": "4.0.0",
    "satori": "0.26.0",
    "satori-html": "0.3.2",
    "sharp": "0.34.5",
    "solid-js": "1.9.12",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.8",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@iconify-json/lucide": "1.2.101",
    "@iconify-json/simple-icons": "1.2.76",
    "@pagefind/default-ui": "1.4.0",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.2",
    "@types/hast": "3.0.4",
    "@types/mdast": "4.0.4",
    "is-ci": "4.1.0",
    "lint-staged": "16.4.0",
    "oxlint": "1.58.0",
    "pagefind": "1.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "reading-time": "1.5.0",
    "simple-git-hooks": "2.13.1",
    "sort-package-json": "3.6.1",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  }
}
